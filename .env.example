# Αντίγραψέ το ως ".env" και συμπλήρωσε τις πραγματικές τιμές.
# Χρησιμοποιείται κυρίως από το Discord bot / tooling εκτός FXServer.

# Discord bot
DISCORD_BOT_TOKEN=CHANGE_ME
DISCORD_GUILD_ID=CHANGE_ME
DISCORD_CLIENT_ID=CHANGE_ME

# Database (MariaDB) — για tools/migrations εκτός oxmysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_DATABASE=olympus_roleplay

# FiveM
FXSERVER_LICENSE_KEY=CHANGE_ME
