### =====================================================
### Olympus RolePlay — server.cfg (template)
### Αντίγραψέ το ως "server.cfg" και συμπλήρωσε τα placeholders
### =====================================================

### ---------------------------------------------------
### Endpoints & Ports
### ---------------------------------------------------
endpoint_add_tcp "0.0.0.0:30120"
endpoint_add_udp "0.0.0.0:30120"

### ---------------------------------------------------
### Server Info
### ---------------------------------------------------
sv_hostname "Olympus RolePlay"
sets sv_projectName "Olympus RolePlay"
sets sv_projectDesc "Greek FiveM Roleplay Server"
sets tags "roleplay, qbox, greek"
sets locale "en-US"

### ---------------------------------------------------
### License Key
### https://keymaster.fivem.net/
### ---------------------------------------------------
sv_licenseKey "CHANGE_ME_LICENSE_KEY"

### ---------------------------------------------------
### Database Connection (oxmysql)
### Μορφή: mysql://user:password@host:port/database
### ---------------------------------------------------
set mysql_connection_string "mysql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@127.0.0.1:3306/olympus_roleplay?charset=utf8mb4"

### ---------------------------------------------------
### Server Slots
### ---------------------------------------------------
sv_maxclients 48

### ---------------------------------------------------
### Steam / Discord API keys
### ---------------------------------------------------
sv_authMaxVariance 1
sv_authMinTrust 5
set steam_webApiKey "CHANGE_ME_STEAM_API_KEY"
set discord_botToken "CHANGE_ME_DISCORD_BOT_TOKEN"

### ---------------------------------------------------
### Resource Loading — Η ΣΕΙΡΑ ΕΧΕΙ ΣΗΜΑΣΙΑ
### ---------------------------------------------------

## 1. ox_lib πρώτο (dependency για όλα τα υπόλοιπα)
ensure ox_lib

## 2. oxmysql δεύτερο (database layer)
ensure oxmysql

## 3. spawnmanager — default FiveM resource, το qbx_core καλεί
##    exports.spawnmanager:spawnPlayer(...) κατά το character load/spawn.
##    Χωρίς αυτό ο client κολλάει σε μαύρη οθόνη (ατελείωτο loop περιμένοντας
##    fade-in που ποτέ δεν έρχεται, γιατί το spawnmanager είναι αυτό που το καλεί).
ensure spawnmanager

## 4. illenium-appearance — outfit/εμφάνιση χαρακτήρα. Το qbx_core καλεί
##    exports['illenium-appearance']:setPedAppearance(...) και το event
##    qb-clothes:client:CreateFirstCharacter τρέχει από εδώ κατά τη δημιουργία νέου χαρακτήρα.
ensure illenium-appearance

## 5. qbx_spawn — classic spawn location picker (Legion Square, Paleto Bay,
##    Motels). Χρησιμοποιείται όταν φορτώνει ΥΠΑΡΧΩΝ χαρακτήρας (Play button).
##    Για ΝΕΟΥΣ χαρακτήρες το spawn γίνεται πάντα στο Job Center μέσω του
##    δικού μας olympus_spawn (βλ. [custom] resources παρακάτω) — έχει προτεραιότητα
##    όταν είναι ενεργό (patched στο qbx_core/client/character.lua).
ensure qbx_spawn

## 6. qbx_core (framework core)
ensure qbx_core

## 7. qbx_vehicles — vehicle ownership/garage data. Απαιτείται (hard
##    dependency, assert-crash αν λείπει) από το ox_inventory bridge, το
##    qbx_garages, και το qbx_vehicleshop — πρέπει να τρέχει πριν από αυτά.
ensure qbx_vehicles

## 8. ox_inventory (inventory system, εξαρτάται από qbx_core)
ensure ox_inventory

## 9. ox_target — target-based interaction (χρησιμοποιείται από το olympus_jobcenter)
ensure ox_target

## 10. PolyZone / qb-target — χρειάζονται από αρκετά από τα qbx_* job resources
##    παρακάτω (zones, εναλλακτικό target system). Πρέπει να τρέχουν πριν από αυτά.
ensure PolyZone
ensure qb-target

## 11. Qbox official job/property resources.
##     ΣΗΜΕΙΩΣΗ: τα qbx_input, qbx_menu, qbx_interact ΔΕΝ βρέθηκαν ως πραγματικά
##     resources κάτω από το Qbox-project στο GitHub — δεν κατεβαίνουν από το
##     install.sh, οπότε ΔΕΝ τα κάνουμε ensure (θα έδινε "Couldn't find resource").
ensure qbx_garages
ensure qbx_vehicleshop
ensure qbx_taxijob
ensure qbx_mechanicjob
ensure qbx_properties
## το "qbx_policejob" έχει μετονομαστεί σε "qbx_police" upstream
ensure qbx_police
ensure qbx_ambulancejob
ensure qbx_truckrobbery
ensure qbx_phone

## 12. Υπόλοιπα [ox] resources
# ensure ox_doorlock

## 13. [standalone] resources
## ΣΗΜΕΙΩΣΗ: το screenshot-basic δεν έχει GitHub release ΚΑΙ απαιτεί webpack
## build (δεν υπάρχουν built dist/ αρχεία στο raw source) — δεν κατεβαίνει
## αυτόματα, βλ. README για χειροκίνητη εγκατάσταση αν το χρειαστείς.
ensure vMenu
ensure bd_loadingscreen
ensure RemoveAllNPCs
## pma-voice — proximity voice (Whisper/Normal/Shouting, cycle με F11). Απαιτεί OneSync.
ensure pma-voice
# ensure <standalone_resource>

## 14. [custom] resources — δικά μας scripts.
## olympus_blips: καθαρό Lua-only resource με τα map blips (Job Center κ.λπ.).
ensure olympus_blips
##
## olympus_hud: dark/gold HUD (status gauges + λεφτά + mic indicator μέσω pma-voice).
## Display-only — δεν παίρνει ΠΟΤΕ NUI focus, άρα ασφαλές (δεν προκαλεί ESC-stuck).
ensure olympus_hud
##
## Το spawn/character creation γίνεται πλέον native μέσα από το qbx_core + illenium
## (single character, auto spawn — δες config/client.lua & client/character.lua),
## οπότε ΔΕΝ χρειαζόμαστε πια το παλιό custom olympus_spawn NUI (που προκαλούσε το
## ESC/NUI-stuck bug). Τα παρακάτω μένουν απενεργοποιημένα:
# ensure olympus_spawn
# ensure olympus_jobcenter

### ---------------------------------------------------
### vMenu — staff/admin only permissions
### Όλα τα permissions ορίζονται στο config/permissions.cfg (μόνο group.admin).
### ---------------------------------------------------
exec config/permissions.cfg

### ---------------------------------------------------
### Convars / Misc
### ---------------------------------------------------
set onesync on
setr onesync_enableInfinity 1
setr inventory:framework "qbx"
sv_enforceGameBuild 2802
sv_scriptHookAllowed 0

## Σβήνει το "Welcome to Qbox!" startup μήνυμα του qbx_core.
set qbx:acknowledge true

### ---------------------------------------------------
### Owner / Admin (steam:xxxxxxxx ή license:xxxxxxxx)
### ---------------------------------------------------
add_ace group.admin command allow
add_ace group.admin command.quit deny
add_principal identifier.CHANGE_ME_ADMIN_ID group.admin
